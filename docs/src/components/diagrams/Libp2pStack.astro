---
import Figure from '../Figure.astro';
---
<Figure id="d-stack">
<svg viewBox="0 0 760 320" role="img" aria-label="The libp2p transport stack" xmlns="http://www.w3.org/2000/svg">
  <rect x="0" y="0" width="760" height="320" rx="10" fill="#0f0f16"/>
  <g class="seq-step" style="--step-i:0">
    <rect x="60" y="36" width="640" height="46" rx="9" fill="#13160f" stroke="#a5ff11" stroke-width="1.4"/>
    <text x="380" y="63" text-anchor="middle" fill="#a5ff11" font-family="'JetBrains Mono', monospace" font-size="11" font-weight="700">Calimero node logic — contexts · governance · sync</text>
  </g>
  <g class="seq-step" style="--step-i:1">
    <rect x="60" y="96" width="312" height="80" rx="9" fill="#10151c" stroke="#58a6ff" stroke-width="1.3"/>
    <text x="216" y="118" text-anchor="middle" fill="#58a6ff" font-family="'JetBrains Mono', monospace" font-size="10" font-weight="700">gossipsub</text>
    <text x="216" y="136" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="8.5">eager broadcast (topics)</text>
    <text x="216" y="158" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="8">deltas · governance · heartbeats</text>
    <rect x="388" y="96" width="312" height="80" rx="9" fill="#16222e" stroke="#39d0d8" stroke-width="1.3"/>
    <text x="544" y="118" text-anchor="middle" fill="#39d0d8" font-family="'JetBrains Mono', monospace" font-size="10" font-weight="700">streams · request-response</text>
    <text x="544" y="136" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="8.5">pull, point-to-point</text>
    <text x="544" y="158" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="8">sync · snapshots · blobs · key recovery</text>
  </g>
  <g class="seq-step" style="--step-i:2">
    <rect x="60" y="190" width="640" height="44" rx="9" fill="#161b22" stroke="#444c56" stroke-width="1.3"/>
    <text x="380" y="217" text-anchor="middle" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="9.5">discovery — rendezvous · mDNS · Kademlia DHT · relay / hole-punch for NAT</text>
  </g>
  <g class="seq-step" style="--step-i:3">
    <rect x="60" y="248" width="640" height="44" rx="9" fill="#161b22" stroke="#444c56" stroke-width="1.3"/>
    <text x="380" y="269" text-anchor="middle" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="9.5">transport — TCP + Noise/TLS · QUIC · Yamux multiplexing</text>
    <text x="380" y="284" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="8">authenticated by transport identity (Chapter 2)</text>
  </g>
</svg>
</Figure>
