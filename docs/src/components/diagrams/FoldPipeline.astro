---
import Figure from '../Figure.astro';
---
<Figure id="d-fold">
<svg viewBox="0 0 760 300" role="img" aria-label="Folding the DAG into state and a root hash" xmlns="http://www.w3.org/2000/svg">
  <defs><marker id="fa" markerWidth="9" markerHeight="9" refX="6.5" refY="3" orient="auto"><path d="M0,0 L6.5,3 L0,6 Z" fill="#8b949e"/></marker></defs>
  <rect x="0" y="0" width="760" height="300" rx="10" fill="#0f0f16"/>
  <!-- DAG -->
  <g class="seq-step" style="--step-i:0">
    <rect x="24" y="70" width="170" height="160" rx="10" fill="#13160f" stroke="#a5ff11" stroke-width="1.3"/>
    <text x="109" y="58" text-anchor="middle" fill="#a5ff11" font-family="'JetBrains Mono', monospace" font-size="11" font-weight="700">Scope DAG</text>
    <circle cx="60" cy="115" r="9" fill="#161b22" stroke="#444c56"/><circle cx="109" cy="150" r="9" fill="#161b22" stroke="#444c56"/>
    <circle cx="60" cy="185" r="9" fill="#161b22" stroke="#444c56"/><circle cx="158" cy="120" r="9" fill="#161b22" stroke="#444c56"/>
    <circle cx="150" cy="190" r="9" fill="#161b22" stroke="#444c56"/>
    <line x1="69" y1="115" x2="100" y2="148" stroke="#3a3a4a"/><line x1="118" y1="150" x2="149" y2="122" stroke="#3a3a4a"/>
    <line x1="69" y1="183" x2="100" y2="153" stroke="#3a3a4a"/><line x1="118" y1="152" x2="142" y2="186" stroke="#3a3a4a"/>
    <text x="109" y="218" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="8.5">signed operations</text>
  </g>
  <g class="seq-step" style="--step-i:1"><line x1="200" y1="150" x2="288" y2="150" stroke="#8b949e" stroke-width="1.4" marker-end="url(#fa)"/>
    <text x="244" y="142" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="8.5">fold</text></g>
  <!-- Projection -->
  <g class="seq-step" style="--step-i:2">
    <rect x="296" y="50" width="200" height="200" rx="10" fill="#10151c" stroke="#58a6ff" stroke-width="1.3"/>
    <text x="396" y="40" text-anchor="middle" fill="#58a6ff" font-family="'JetBrains Mono', monospace" font-size="11" font-weight="700">Projection — per-slot LWW</text>
    <text x="312" y="86" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="9.5">entities  →  value · stamp</text>
    <text x="312" y="112" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="9.5">acl       →  writers · stamp</text>
    <text x="312" y="138" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="9.5">groups    →  members · stamp</text>
    <text x="312" y="164" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="9.5">admin     →  identity · stamp</text>
    <text x="312" y="190" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="9.5">policy    →  bytes · stamp</text>
    <text x="312" y="216" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="9.5">subgroups →  tree · stamp</text>
    <text x="312" y="242" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="9.5">caps      →  grants · stamp</text>
  </g>
  <g class="seq-step" style="--step-i:3"><line x1="502" y1="150" x2="590" y2="150" stroke="#8b949e" stroke-width="1.4" marker-end="url(#fa)"/>
    <text x="546" y="142" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="8.5">hash</text></g>
  <!-- root -->
  <g class="seq-step" style="--step-i:4">
    <rect x="598" y="105" width="148" height="90" rx="10" fill="#1f2a12" stroke="#a5ff11" stroke-width="1.5"/>
    <text x="672" y="135" text-anchor="middle" fill="#a5ff11" font-family="'JetBrains Mono', monospace" font-size="11" font-weight="700">scope_root</text>
    <text x="672" y="158" text-anchor="middle" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="8.5">H( entities ‖</text>
    <text x="672" y="172" text-anchor="middle" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="8.5">acl ‖ governance )</text>
  </g>
</svg>
</Figure>
