---
import Figure from '../Figure.astro';
---
<Figure id="d-dag">
<svg viewBox="0 0 760 360" role="img" aria-label="A scope's causal DAG" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <marker id="pa" markerWidth="9" markerHeight="9" refX="6.5" refY="3" orient="auto"><path d="M0,0 L6.5,3 L0,6 Z" fill="#8b949e"/></marker>
    <marker id="pad" markerWidth="9" markerHeight="9" refX="6.5" refY="3" orient="auto"><path d="M0,0 L6.5,3 L0,6 Z" fill="#6b6b80"/></marker>
  </defs>
  <rect x="0" y="0" width="760" height="360" rx="10" fill="#0f0f16"/>
  <text x="20" y="28" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="10">causal time →</text>

  <!-- genesis -->
  <g class="seq-step" style="--step-i:0">
    <circle cx="55" cy="160" r="20" fill="#22272e" stroke="#58a6ff" stroke-width="1.4"/>
    <text x="55" y="165" text-anchor="middle" fill="#58a6ff" font-family="'JetBrains Mono', monospace" font-size="14" font-weight="700">∅</text>
    <text x="55" y="200" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="9">genesis</text>
  </g>
  <!-- A -->
  <g class="seq-step" style="--step-i:1">
    <line x1="120" y1="160" x2="82" y2="160" stroke="#8b949e" stroke-width="1.4" marker-end="url(#pa)"/>
    <rect x="120" y="141" width="92" height="38" rx="9" fill="#161b22" stroke="#444c56" stroke-width="1.4"/>
    <text x="166" y="160" text-anchor="middle" fill="#f0f6fc" font-family="'JetBrains Mono', monospace" font-size="13" font-weight="700">A</text>
    <text x="166" y="173" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="8.5">Put</text>
  </g>
  <!-- B (concurrent) -->
  <g class="seq-step" style="--step-i:2">
    <line x1="272" y1="98" x2="206" y2="146" stroke="#8b949e" stroke-width="1.4" marker-end="url(#pa)"/>
    <rect x="272" y="80" width="92" height="38" rx="9" fill="#161b22" stroke="#444c56" stroke-width="1.4"/>
    <text x="318" y="99" text-anchor="middle" fill="#f0f6fc" font-family="'JetBrains Mono', monospace" font-size="13" font-weight="700">B</text>
    <text x="318" y="112" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="8.5">MemberAdded</text>
  </g>
  <!-- C (concurrent) -->
  <g class="seq-step" style="--step-i:3">
    <line x1="272" y1="222" x2="206" y2="174" stroke="#8b949e" stroke-width="1.4" marker-end="url(#pa)"/>
    <rect x="272" y="203" width="92" height="38" rx="9" fill="#161b22" stroke="#444c56" stroke-width="1.4"/>
    <text x="318" y="222" text-anchor="middle" fill="#f0f6fc" font-family="'JetBrains Mono', monospace" font-size="13" font-weight="700">C</text>
    <text x="318" y="235" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="8.5">Put</text>
  </g>
  <text x="318" y="270" text-anchor="middle" fill="#f0883e" font-family="'JetBrains Mono', monospace" font-size="9" class="seq-step" style="--step-i:3">B and C are concurrent (neither is an ancestor of the other)</text>
  <!-- D merge head -->
  <g class="seq-step" style="--step-i:4">
    <line x1="448" y1="150" x2="366" y2="99" stroke="#8b949e" stroke-width="1.4" marker-end="url(#pa)"/>
    <line x1="448" y1="170" x2="366" y2="222" stroke="#8b949e" stroke-width="1.4" marker-end="url(#pa)"/>
    <rect x="448" y="141" width="110" height="38" rx="9" fill="#1f2a12" stroke="#a5ff11" stroke-width="1.6"/>
    <text x="503" y="160" text-anchor="middle" fill="#f0f6fc" font-family="'JetBrains Mono', monospace" font-size="13" font-weight="700">D</text>
    <text x="503" y="173" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="8.5">merges B + C</text>
    <rect x="566" y="146" width="40" height="17" rx="4" fill="#1f2a12" stroke="#a5ff11" stroke-width="1"/>
    <text x="586" y="158" text-anchor="middle" fill="#a5ff11" font-family="'JetBrains Mono', monospace" font-size="8.5" font-weight="700">head</text>
  </g>
  <!-- pending -->
  <g class="seq-step" style="--step-i:5">
    <circle cx="503" cy="290" r="15" fill="#16181d" stroke="#30363d" stroke-width="1.4" stroke-dasharray="3 3"/>
    <text x="503" y="294" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="12">?</text>
    <line x1="488" y1="290" x2="424" y2="290" stroke="#6b6b80" stroke-width="1.3" stroke-dasharray="4 3" marker-end="url(#pad)"/>
    <rect x="330" y="281" width="92" height="38" rx="9" fill="#16181d" stroke="#30363d" stroke-width="1.4" stroke-dasharray="4 3"/>
    <text x="376" y="300" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="13" font-weight="700">P</text>
    <text x="376" y="313" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="8.5">pending — parent missing</text>
  </g>
</svg>
</Figure>
