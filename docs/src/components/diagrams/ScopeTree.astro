---
import Figure from '../Figure.astro';
---
<Figure id="d-scope-tree">
<svg viewBox="0 0 760 366" role="img" aria-label="The scope tree" xmlns="http://www.w3.org/2000/svg">
  <rect x="0" y="0" width="760" height="366" rx="10" fill="#0f0f16"/>
  <!-- edges -->
  <g class="seq-step" style="--step-i:1">
    <line x1="345" y1="90" x2="245" y2="163" stroke="#8b949e" stroke-width="1.3" stroke-dasharray="4 3"/>
    <line x1="425" y1="90" x2="525" y2="163" stroke="#8b949e" stroke-width="1.3" stroke-dasharray="4 3"/>
  </g>
  <g class="seq-step" style="--step-i:3">
    <line x1="232" y1="225" x2="232" y2="285" stroke="#8b949e" stroke-width="1.3" stroke-dasharray="4 3"/>
  </g>
  <!-- root governance scope -->
  <g class="seq-step" style="--step-i:0">
    <rect x="230" y="30" width="300" height="60" rx="11" fill="#1f2a12" stroke="#a5ff11" stroke-width="1.4"/>
    <text x="380" y="56" text-anchor="middle" fill="#f0f6fc" font-family="'JetBrains Mono', monospace" font-size="13" font-weight="700">Root governance scope</text>
    <text x="380" y="76" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="10.5">members · admin · policy</text>
  </g>
  <!-- subgroup + context (level 2) -->
  <g class="seq-step" style="--step-i:2">
    <rect x="120" y="165" width="224" height="60" rx="11" fill="#1f2a12" stroke="#a5ff11" stroke-width="1.4"/>
    <text x="232" y="191" text-anchor="middle" fill="#f0f6fc" font-family="'JetBrains Mono', monospace" font-size="13" font-weight="700">Subgroup scope</text>
    <text x="232" y="211" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="10.5">own key · own members</text>
    <rect x="416" y="165" width="240" height="60" rx="11" fill="#16222e" stroke="#58a6ff" stroke-width="1.4"/>
    <text x="536" y="191" text-anchor="middle" fill="#f0f6fc" font-family="'JetBrains Mono', monospace" font-size="13" font-weight="700">Context scope</text>
    <text x="536" y="211" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="10.5">app state operations</text>
  </g>
  <!-- nested context (level 3) -->
  <g class="seq-step" style="--step-i:4">
    <rect x="120" y="287" width="224" height="60" rx="11" fill="#16222e" stroke="#58a6ff" stroke-width="1.4"/>
    <text x="232" y="313" text-anchor="middle" fill="#f0f6fc" font-family="'JetBrains Mono', monospace" font-size="13" font-weight="700">Context scope</text>
    <text x="232" y="333" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="10.5">app state operations</text>
  </g>
</svg>
</Figure>
