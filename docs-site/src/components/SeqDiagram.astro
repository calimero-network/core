---
/**
 * SeqDiagram — the bespoke animated sequence-diagram engine, mounted as an
 * Astro island. Proves Phase 0's central claim: we keep our custom interactive
 * diagrams while authoring content in Markdown/MDX.
 *
 * Usage in MDX:
 *   <SeqDiagram id="d-op-life" title="The life of an operation"
 *     lanes={[{label:'Author',color:'#3fb950'}, ...]}
 *     steps={[{from:0,to:0,label:'build Op'}, ...]} />
 *
 * A `lane` = { label, color }. A `step` = { from, to, label, dashed?, color? }
 * (from===to draws a self-call) | { type:'divider', label }.
 */
interface Lane { label: string; color: string }
interface Step { from?: number; to?: number; label: string; dashed?: boolean; color?: string; type?: string }
interface Props { id: string; title: string; lanes: Lane[]; steps: Step[] }

const { id, title, lanes, steps } = Astro.props as Props;
const data = JSON.stringify({ title, lanes, steps });
---

<div class="diagram-tools">
  <button class="replay-btn" data-replay={id}>&#9654; Replay</button>
</div>
<div class="diagram-container seq animating" id={id} data-seq={data}></div>

<script>
  const NS = 'http://www.w3.org/2000/svg';
  function S(tag: string, a?: Record<string, string | number> | null, txt?: string | null) {
    const e = document.createElementNS(NS, tag);
    if (a) Object.keys(a).forEach((k) => e.setAttribute(k, String(a[k])));
    if (txt != null) e.textContent = txt;
    return e;
  }

  function render(box: HTMLElement) {
    const data = JSON.parse(box.dataset.seq || '{}');
    const lanes = data.lanes || [];
    const steps = data.steps || [];
    box.textContent = '';
    const n = lanes.length, m = steps.length;
    const L = 48, R = 18;
    const W = Math.max(960, L + n * 150 + R);
    const SS = 90, SH = 52;
    const H = SS + m * SH + 28;
    const lw = (W - L - R) / n;
    const cx = lanes.map((_: unknown, i: number) => L + lw * i + lw / 2);

    const svg = S('svg', { viewBox: `0 0 ${W} ${H}`, role: 'img', 'aria-label': `${data.title} sequence diagram` });
    svg.appendChild(S('title', null, data.title));
    svg.appendChild(S('rect', { x: 0, y: 0, width: W, height: H, fill: '#0f0f16', rx: 10 }));

    lanes.forEach((lane: any, i: number) => {
      const x = cx[i], hw = Math.min(lw - 10, 134);
      svg.appendChild(S('rect', { x: x - hw / 2, y: 10, width: hw, height: 32, rx: 6, fill: lane.color + '18', stroke: lane.color + '50', 'stroke-width': 1 }));
      svg.appendChild(S('text', { x, y: 31, 'text-anchor': 'middle', fill: lane.color, 'font-family': 'var(--sl-font-mono)', 'font-size': lane.label.length > 11 ? '9.5' : '10.5', 'font-weight': '600' }, lane.label));
      svg.appendChild(S('line', { x1: x, y1: 48, x2: x, y2: H - 14, stroke: '#252538', 'stroke-width': 1, 'stroke-dasharray': '3,4' }));
    });

    let stepNum = 0;
    steps.forEach((step: any, i: number) => {
      const y = SS + i * SH;
      const g = S('g', { class: 'seq-step', style: `--step-i:${i}` });
      if (step.type === 'divider') {
        g.appendChild(S('line', { x1: L, y1: y, x2: W - R, y2: y, stroke: '#35354a', 'stroke-width': 1, 'stroke-dasharray': '6,4' }));
        const dlw = step.label.length * 6.2 + 24;
        g.appendChild(S('rect', { x: W / 2 - dlw / 2, y: y - 11, width: dlw, height: 20, fill: '#0f0f16', rx: 4 }));
        g.appendChild(S('text', { x: W / 2, y: y + 4, 'text-anchor': 'middle', fill: '#9aa4b2', 'font-family': 'var(--sl-font)', 'font-size': '10.5', 'font-style': 'italic' }, step.label));
        svg.appendChild(g);
        return;
      }
      stepNum++;
      g.appendChild(S('text', { x: 12, y: y + 4, fill: '#5a6472', 'font-family': 'var(--sl-font-mono)', 'font-size': '9.5', 'font-weight': '700' }, String(stepNum)));
      const fx = cx[step.from], tx = cx[step.to];
      const col = step.color || lanes[step.to].color;
      if (step.from === step.to) {
        const rightSide = step.from < n - 1;
        const dir = rightSide ? 1 : -1;
        const lp = 36, lh = 18, sx = fx + dir * 3;
        g.appendChild(S('path', { d: `M ${sx},${y - lh / 2} h ${dir * lp} v ${lh} h ${dir * -lp}`, fill: 'none', stroke: col, 'stroke-width': 1.3 }));
        const ax = sx, ay = y + lh / 2;
        g.appendChild(S('polygon', { points: `${ax + dir * 5},${ay - 3.5} ${ax},${ay} ${ax + dir * 5},${ay + 3.5}`, fill: col }));
        g.appendChild(S('text', { x: fx + dir * (lp + 10), y: y + 3, 'text-anchor': rightSide ? 'start' : 'end', fill: col, 'font-family': 'var(--sl-font-mono)', 'font-size': '9', 'font-weight': '500' }, step.label));
      } else {
        const d = tx > fx ? 1 : -1;
        const x1 = fx + d * 5, x2 = tx - d * 5;
        g.appendChild(S('circle', { cx: fx, cy: y, r: 2.5, fill: col + '70' }));
        g.appendChild(S('circle', { cx: tx, cy: y, r: 3, fill: col }));
        const dashVal = step.dashed ? '5,3' : 'none';
        const opVal = step.dashed ? '.55' : '1';
        g.appendChild(S('line', { x1, y1: y, x2, y2: y, stroke: col, 'stroke-width': 1.5, 'stroke-dasharray': dashVal, 'stroke-opacity': opVal }));
        g.appendChild(S('polygon', { points: `${x2},${y} ${x2 - d * 7},${y - 3.5} ${x2 - d * 7},${y + 3.5}`, fill: col, 'fill-opacity': opVal }));
        g.appendChild(S('text', { x: (x1 + x2) / 2, y: y - 8, 'text-anchor': 'middle', fill: '#c4c4cc', 'font-family': 'var(--sl-font-mono)', 'font-size': '9.5' }, step.label));
      }
      svg.appendChild(g);
    });
    box.appendChild(svg);
  }

  function replay(el: HTMLElement) {
    el.classList.remove('animating');
    void el.offsetWidth;
    el.classList.add('animating');
  }

  function init() {
    document.querySelectorAll<HTMLElement>('[data-seq]').forEach(render);
    document.querySelectorAll<HTMLElement>('[data-replay]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = document.getElementById(btn.dataset.replay || '');
        if (target) replay(target);
      });
    });
  }
  init();
  // Re-init after Starlight client-side navigation.
  document.addEventListener('astro:page-load', init);
</script>
