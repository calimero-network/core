---
/**
 * ActorModel — block diagram of a running node's Actix actors and long-lived
 * tasks, plus the message/data flow between them. Authored as an Astro
 * component so the raw SVG (with hyphenated attrs) is first-class; the MDX
 * page only references <ActorModel />. Dark-theme palette matches ArchMap.
 */
---
<div class="actormodel">
<svg viewBox="0 0 760 462" role="img" aria-label="Calimero node actor model" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <marker id="am-head" markerWidth="8" markerHeight="8" refX="5.5" refY="3" orient="auto-start-reverse">
      <path d="M0,0 L6,3 L0,6 Z" fill="#8b949e"/>
    </marker>
  </defs>
  <rect x="0" y="0" width="760" height="462" rx="12" fill="#0d1117"/>

  <!-- Server layer -->
  <rect x="20" y="18" width="720" height="44" rx="9" fill="#231708" stroke="#e3b341" stroke-width="1.4"/>
  <text x="380" y="38" text-anchor="middle" fill="#e3b341" font-family="ui-sans-serif, system-ui" font-size="13" font-weight="600">Server layer — REST · JSON-RPC · WebSocket · SSE</text>
  <text x="380" y="54" text-anchor="middle" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="9.5">crates/server — no business logic, delegates through client façades</text>

  <!-- Server -> actor façade arrows -->
  <line x1="125" y1="62" x2="125" y2="118" stroke="#8b949e" stroke-width="1.3" marker-end="url(#am-head)"/>
  <line x1="380" y1="62" x2="380" y2="118" stroke="#8b949e" stroke-width="1.3" marker-end="url(#am-head)"/>
  <rect x="86" y="82" width="78" height="16" rx="4" fill="#0d1117" stroke="#30363d" stroke-width="1"/>
  <text x="125" y="93" text-anchor="middle" fill="#c9d1d9" font-family="ui-monospace, monospace" font-size="8">ContextClient</text>
  <rect x="347" y="82" width="66" height="16" rx="4" fill="#0d1117" stroke="#30363d" stroke-width="1"/>
  <text x="380" y="93" text-anchor="middle" fill="#c9d1d9" font-family="ui-monospace, monospace" font-size="8">NodeClient</text>

  <!-- Actor row: Context | Node | Network -->
  <!-- ContextManager -->
  <rect x="20" y="118" width="210" height="92" rx="10" fill="#10210f" stroke="#3fb950" stroke-width="1.4"/>
  <text x="32" y="142" fill="#3fb950" font-family="ui-sans-serif, system-ui" font-size="13" font-weight="700">ContextManager</text>
  <rect x="170" y="128" width="48" height="16" rx="4" fill="#10210f" stroke="#3fb950" stroke-width="0.9"/>
  <text x="194" y="139" text-anchor="middle" fill="#3fb950" font-family="ui-monospace, monospace" font-size="8" font-weight="600">actor</text>
  <text x="32" y="166" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8.5">contexts · groups · governance DAGs</text>
  <text x="32" y="181" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8.5">30+ handlers — execution · membership</text>
  <text x="32" y="201" fill="#5d8a5f" font-family="ui-monospace, monospace" font-size="7.5">crates/context · Handler&lt;ContextMessage&gt;</text>

  <!-- NodeManager -->
  <rect x="275" y="118" width="210" height="92" rx="10" fill="#10151c" stroke="#58a6ff" stroke-width="1.4"/>
  <text x="287" y="142" fill="#58a6ff" font-family="ui-sans-serif, system-ui" font-size="13" font-weight="700">NodeManager</text>
  <rect x="425" y="128" width="48" height="16" rx="4" fill="#10151c" stroke="#58a6ff" stroke-width="0.9"/>
  <text x="449" y="139" text-anchor="middle" fill="#58a6ff" font-family="ui-monospace, monospace" font-size="8" font-weight="600">actor</text>
  <text x="287" y="166" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8.5">central orchestrator — routes deltas</text>
  <text x="287" y="181" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8.5">blob cache (LRU) · heartbeats · keys</text>
  <text x="287" y="201" fill="#5d7da6" font-family="ui-monospace, monospace" font-size="7.5">crates/node · Handler&lt;NodeMessage&gt;</text>

  <!-- NetworkManager -->
  <rect x="530" y="118" width="210" height="92" rx="10" fill="#1a1430" stroke="#a371f7" stroke-width="1.4"/>
  <text x="542" y="142" fill="#a371f7" font-family="ui-sans-serif, system-ui" font-size="13" font-weight="700">NetworkManager</text>
  <rect x="680" y="128" width="48" height="16" rx="4" fill="#1a1430" stroke="#a371f7" stroke-width="0.9"/>
  <text x="704" y="139" text-anchor="middle" fill="#a371f7" font-family="ui-monospace, monospace" font-size="8" font-weight="600">actor</text>
  <text x="542" y="166" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8.5">owns the libp2p Swarm</text>
  <text x="542" y="181" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8.5">gossipsub · Kademlia · streams</text>
  <text x="542" y="201" fill="#6f5ca6" font-family="ui-monospace, monospace" font-size="7.5">crates/network · Handler&lt;NetworkMessage&gt;</text>

  <!-- Context <-> Node (state deltas) -->
  <line x1="230" y1="168" x2="275" y2="168" stroke="#8b949e" stroke-width="1.3" marker-start="url(#am-head)" marker-end="url(#am-head)"/>
  <text x="252" y="160" text-anchor="middle" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8">deltas</text>

  <!-- Node <-> Network (publish / event) -->
  <line x1="485" y1="156" x2="530" y2="156" stroke="#8b949e" stroke-width="1.3" marker-end="url(#am-head)"/>
  <text x="507" y="149" text-anchor="middle" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8">publish</text>
  <line x1="530" y1="184" x2="485" y2="184" stroke="#8b949e" stroke-width="1.3" marker-end="url(#am-head)"/>
  <text x="507" y="196" text-anchor="middle" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8">event</text>

  <!-- Tasks row -->
  <!-- SyncManager -->
  <rect x="275" y="258" width="210" height="76" rx="10" fill="#231708" stroke="#e3b341" stroke-width="1.4"/>
  <text x="287" y="282" fill="#e3b341" font-family="ui-sans-serif, system-ui" font-size="12" font-weight="700">SyncManager</text>
  <rect x="403" y="268" width="70" height="16" rx="4" fill="#231708" stroke="#e3b341" stroke-width="0.9"/>
  <text x="438" y="279" text-anchor="middle" fill="#e3b341" font-family="ui-monospace, monospace" font-size="8" font-weight="600">async task</text>
  <text x="287" y="304" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8.5">periodic + on-demand sync cycles</text>
  <text x="287" y="318" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8.5">picks protocol from divergence metrics</text>
  <text x="287" y="330" fill="#a8772b" font-family="ui-monospace, monospace" font-size="7.5">crates/node · tokio task · uses NetworkClient</text>

  <!-- GarbageCollector -->
  <rect x="530" y="258" width="210" height="76" rx="10" fill="#161b22" stroke="#8b949e" stroke-width="1.3"/>
  <text x="542" y="282" fill="#c9d1d9" font-family="ui-sans-serif, system-ui" font-size="12" font-weight="700">GarbageCollector</text>
  <rect x="688" y="268" width="46" height="16" rx="4" fill="#161b22" stroke="#8b949e" stroke-width="0.9"/>
  <text x="711" y="279" text-anchor="middle" fill="#8b949e" font-family="ui-monospace, monospace" font-size="8" font-weight="600">actor</text>
  <text x="542" y="304" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8.5">background storage cleanup</text>
  <text x="542" y="318" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8.5">removes tombstones on a timer</text>
  <text x="542" y="330" fill="#6e7681" font-family="ui-monospace, monospace" font-size="7.5">crates/node</text>

  <!-- Node -> SyncManager -->
  <line x1="380" y1="210" x2="380" y2="258" stroke="#8b949e" stroke-width="1.3" marker-start="url(#am-head)" marker-end="url(#am-head)"/>
  <rect x="324" y="226" width="112" height="16" rx="4" fill="#0d1117" stroke="#30363d" stroke-width="1"/>
  <text x="380" y="237" text-anchor="middle" fill="#c9d1d9" font-family="ui-monospace, monospace" font-size="7.5">broadcast channel</text>
  <!-- Node -> GarbageCollector -->
  <line x1="470" y1="210" x2="560" y2="258" stroke="#8b949e" stroke-width="1.2" stroke-dasharray="4 3" marker-end="url(#am-head)"/>
  <text x="540" y="244" text-anchor="middle" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8">spawns</text>

  <!-- Supporting libs bar -->
  <rect x="20" y="372" width="720" height="48" rx="10" fill="#10201f" stroke="#39d0d8" stroke-width="1.3"/>
  <line x1="260" y1="376" x2="260" y2="416" stroke="#39d0d833" stroke-width="1"/>
  <line x1="500" y1="376" x2="500" y2="416" stroke="#39d0d833" stroke-width="1"/>
  <text x="140" y="393" text-anchor="middle" fill="#39d0d8" font-family="ui-sans-serif, system-ui" font-size="11" font-weight="600">Runtime</text>
  <text x="140" y="408" text-anchor="middle" fill="#8b949e" font-family="ui-monospace, monospace" font-size="8">crates/runtime · WASM</text>
  <text x="380" y="393" text-anchor="middle" fill="#39d0d8" font-family="ui-sans-serif, system-ui" font-size="11" font-weight="600">Causal DAG</text>
  <text x="380" y="408" text-anchor="middle" fill="#8b949e" font-family="ui-monospace, monospace" font-size="8">crates/dag</text>
  <text x="620" y="393" text-anchor="middle" fill="#39d0d8" font-family="ui-sans-serif, system-ui" font-size="11" font-weight="600">Storage</text>
  <text x="620" y="408" text-anchor="middle" fill="#8b949e" font-family="ui-monospace, monospace" font-size="8">crates/store + crates/storage</text>

  <!-- actor tier -> libs bar -->
  <line x1="125" y1="210" x2="125" y2="372" stroke="#8b949e" stroke-width="1.2" stroke-dasharray="4 3" marker-end="url(#am-head)"/>
  <text x="133" y="300" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8">execute</text>
  <line x1="380" y1="334" x2="380" y2="372" stroke="#8b949e" stroke-width="1.2" stroke-dasharray="4 3" marker-end="url(#am-head)"/>
  <text x="388" y="356" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="8">persist</text>

  <!-- caption -->
  <text x="380" y="446" text-anchor="middle" fill="#6b7280" font-family="ui-sans-serif, system-ui" font-size="9.5">Actors exchange typed messages through thin client façades (LazyRecipient); the network layer moves opaque bytes only.</text>
</svg>
</div>

<style>
  .actormodel { margin: 1.5rem 0; }
  .actormodel svg { width: 100%; height: auto; border-radius: 12px; }
</style>
