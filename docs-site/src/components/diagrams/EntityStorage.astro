---
/**
 * EntityStorage — how the app's CRDT structs / collections / private data are
 * stored. Logical struct → content-addressed entities → RocksDB `State` CF rows.
 * Authored as raw SVG so hyphenated attrs pass through untouched.
 */
import Figure from '../Figure.astro';
---
<Figure id="d-entity-storage">
<svg width="100%" viewBox="0 0 760 500" role="img" aria-label="How CRDT structs, collections and private data are stored as content-addressed entities" xmlns="http://www.w3.org/2000/svg">
  <defs><marker id="es-a" markerWidth="9" markerHeight="9" refX="6.5" refY="3" orient="auto"><path d="M0,0 L6.5,3 L0,6 Z" fill="#8b949e"/></marker></defs>
  <rect x="0" y="0" width="760" height="500" rx="10" fill="#0d1117"/>

  <!-- column headers -->
  <text x="127" y="40" text-anchor="middle" fill="#58a6ff" font-family="'JetBrains Mono', monospace" font-size="11" font-weight="700">1 · Logical</text>
  <text x="380" y="40" text-anchor="middle" fill="#a371f7" font-family="'JetBrains Mono', monospace" font-size="11" font-weight="700">2 · Entities</text>
  <text x="633" y="40" text-anchor="middle" fill="#39d0d8" font-family="'JetBrains Mono', monospace" font-size="11" font-weight="700">3 · Storage — State CF</text>

  <!-- column 1: logical struct (code-ish box) -->
  <g class="seq-step" style="--step-i:0">
    <rect x="18" y="58" width="218" height="156" rx="10" fill="#10151c" stroke="#58a6ff" stroke-width="1.4"/>
    <text x="34" y="88" fill="#f0883e" font-family="'JetBrains Mono', monospace" font-size="10.5">#[app::state]</text>
    <text x="34" y="110" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="10.5">struct App {</text>
    <text x="46" y="132" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="10.5">msgs:</text>
    <text x="58" y="154" fill="#58a6ff" font-family="'JetBrains Mono', monospace" font-size="10.5">UnorderedMap&lt;</text>
    <text x="70" y="176" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="10.5">String, Message&gt;</text>
    <text x="34" y="198" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="10.5">}</text>
  </g>

  <!-- arrow 1 -> 2 -->
  <g class="seq-step" style="--step-i:1">
    <line x1="236" y1="135" x2="288" y2="135" stroke="#8b949e" stroke-width="1.4" marker-end="url(#es-a)"/>
    <text x="262" y="127" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="8">stored as</text>
  </g>

  <!-- column 2: entity tree -->
  <g class="seq-step" style="--step-i:2">
    <!-- root entity -->
    <rect x="300" y="60" width="160" height="42" rx="9" fill="#1a1430" stroke="#a371f7" stroke-width="1.4"/>
    <text x="380" y="79" text-anchor="middle" fill="#f0f6fc" font-family="'JetBrains Mono', monospace" font-size="10" font-weight="700">root entity</text>
    <text x="380" y="94" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="8.5">App</text>
    <line x1="380" y1="102" x2="380" y2="138" stroke="#8b949e" stroke-width="1.3" marker-end="url(#es-a)"/>
  </g>
  <g class="seq-step" style="--step-i:3">
    <!-- msgs collection entity -->
    <rect x="288" y="140" width="184" height="62" rx="9" fill="#10210f" stroke="#3fb950" stroke-width="1.4"/>
    <text x="380" y="160" text-anchor="middle" fill="#3fb950" font-family="'JetBrains Mono', monospace" font-size="9.5" font-weight="700">'msgs' — collection entity</text>
    <text x="380" y="178" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="7.5">id = SHA256(parent ‖</text>
    <text x="380" y="190" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="7.5">'__calimero_collection__' ‖ 'msgs')</text>
    <!-- branch to children -->
    <line x1="380" y1="202" x2="380" y2="222" stroke="#8b949e" stroke-width="1.3"/>
    <line x1="380" y1="222" x2="322" y2="222" stroke="#8b949e" stroke-width="1.3"/>
    <line x1="380" y1="222" x2="438" y2="222" stroke="#8b949e" stroke-width="1.3"/>
    <line x1="322" y1="222" x2="322" y2="246" stroke="#8b949e" stroke-width="1.3" marker-end="url(#es-a)"/>
    <line x1="438" y1="222" x2="438" y2="246" stroke="#8b949e" stroke-width="1.3" marker-end="url(#es-a)"/>
  </g>
  <g class="seq-step" style="--step-i:4">
    <!-- child entity A -->
    <rect x="270" y="248" width="104" height="68" rx="9" fill="#16222e" stroke="#39d0d8" stroke-width="1.3"/>
    <text x="322" y="268" text-anchor="middle" fill="#f0f6fc" font-family="'JetBrains Mono', monospace" font-size="9" font-weight="700">entry 'alice'</text>
    <text x="322" y="284" text-anchor="middle" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="8.5">Message value</text>
    <text x="322" y="304" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="7">'__calimero_entry__'</text>
    <!-- child entity B -->
    <rect x="386" y="248" width="104" height="68" rx="9" fill="#16222e" stroke="#39d0d8" stroke-width="1.3"/>
    <text x="438" y="268" text-anchor="middle" fill="#f0f6fc" font-family="'JetBrains Mono', monospace" font-size="9" font-weight="700">entry 'bob'</text>
    <text x="438" y="284" text-anchor="middle" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="8.5">Message value</text>
    <text x="438" y="304" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="7">'__calimero_entry__'</text>
    <!-- id derivation note -->
    <text x="380" y="334" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="8">child id = SHA256(parent ‖ '__calimero_entry__' ‖ key)</text>
  </g>

  <!-- arrow 2 -> 3 -->
  <g class="seq-step" style="--step-i:5">
    <line x1="492" y1="200" x2="522" y2="200" stroke="#8b949e" stroke-width="1.4" marker-end="url(#es-a)"/>
    <text x="507" y="192" text-anchor="middle" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="8">persist</text>
  </g>

  <!-- column 3: State CF rows -->
  <g class="seq-step" style="--step-i:6">
    <rect x="524" y="62" width="218" height="56" rx="9" fill="#10201f" stroke="#39d0d8" stroke-width="1.3"/>
    <text x="540" y="84" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="9">context_id ‖ alice_id</text>
    <text x="540" y="104" fill="#39d0d8" font-family="'JetBrains Mono', monospace" font-size="9.5">→ Borsh(Message)</text>

    <rect x="524" y="128" width="218" height="56" rx="9" fill="#10201f" stroke="#39d0d8" stroke-width="1.3"/>
    <text x="540" y="150" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="9">context_id ‖ bob_id</text>
    <text x="540" y="170" fill="#39d0d8" font-family="'JetBrains Mono', monospace" font-size="9.5">→ Borsh(Message)</text>

    <rect x="524" y="194" width="218" height="56" rx="9" fill="#10201f" stroke="#39d0d8" stroke-width="1.3"/>
    <text x="540" y="216" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="9">context_id ‖ msgs_coll_id</text>
    <text x="540" y="236" fill="#39d0d8" font-family="'JetBrains Mono', monospace" font-size="9.5">→ Borsh(collection meta)</text>

    <text x="633" y="266" text-anchor="middle" fill="#6b6b80" font-family="'JetBrains Mono', monospace" font-size="8">key = context_id(32) ‖ entity_id(32)</text>
  </g>

  <!-- side note -->
  <g class="seq-step" style="--step-i:7">
    <rect x="18" y="392" width="724" height="64" rx="10" fill="#231708" stroke="#e3b341" stroke-width="1.3"/>
    <text x="34" y="416" fill="#e3b341" font-family="'JetBrains Mono', monospace" font-size="9.5" font-weight="700">Nested collections recurse the same way (collection-id separator).</text>
    <text x="34" y="438" fill="#c9d1d9" font-family="'JetBrains Mono', monospace" font-size="9.5">#[app::private] → PrivateState CF: node-local, never synced, outside the Merkle root.</text>
  </g>

  <!-- caption -->
  <text x="380" y="482" text-anchor="middle" fill="#6b7280" font-family="ui-sans-serif, system-ui" font-size="10.5">Entity-per-value; ids are content-derived, so every node computes the same id for the same key.</text>
</svg>
</Figure>
