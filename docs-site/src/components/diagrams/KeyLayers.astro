---
import Figure from '../Figure.astro';
---
<Figure id="d-keys">
<svg viewBox="0 0 760 300" role="img" aria-label="The three key layers" xmlns="http://www.w3.org/2000/svg">
  <rect x="0" y="0" width="760" height="300" rx="10" fill="#0f0f16"/>
  <g class="seq-step" style="--step-i:0">
    <rect x="40" y="30" width="680" height="68" rx="10" fill="#10151c" stroke="#58a6ff" stroke-width="1.4"/>
    <text x="64" y="58" fill="#58a6ff" font-family="'JetBrains Mono', monospace" font-size="12" font-weight="700">Transport identity</text>
    <text x="64" y="80" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="10">Ed25519 → libp2p PeerId · per node · names the node on the wire</text>
    <text x="700" y="70" text-anchor="end" fill="#3a4250" font-family="'JetBrains Mono', monospace" font-size="34" font-weight="700">node</text>
  </g>
  <g class="seq-step" style="--step-i:1">
    <rect x="40" y="116" width="680" height="68" rx="10" fill="#13160f" stroke="#a5ff11" stroke-width="1.4"/>
    <text x="64" y="144" fill="#a5ff11" font-family="'JetBrains Mono', monospace" font-size="12" font-weight="700">Member identity</text>
    <text x="64" y="166" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="10">Ed25519 → namespace keypair · per namespace · authors &amp; signs operations</text>
    <text x="700" y="156" text-anchor="end" fill="#2c3520" font-family="'JetBrains Mono', monospace" font-size="30" font-weight="700">namespace</text>
  </g>
  <g class="seq-step" style="--step-i:2">
    <rect x="40" y="202" width="680" height="68" rx="10" fill="#16222e" stroke="#39d0d8" stroke-width="1.4"/>
    <text x="64" y="230" fill="#39d0d8" font-family="'JetBrains Mono', monospace" font-size="12" font-weight="700">Scope key</text>
    <text x="64" y="252" fill="#8b949e" font-family="'JetBrains Mono', monospace" font-size="10">symmetric · per scope · encrypts operations · delivered ECDH-wrapped</text>
    <text x="700" y="242" text-anchor="end" fill="#1d3038" font-family="'JetBrains Mono', monospace" font-size="34" font-weight="700">scope</text>
  </g>
</svg>
</Figure>
