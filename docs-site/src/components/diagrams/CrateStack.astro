---
/**
 * CrateStack — the layered crate map of the workspace, from external surfaces
 * at the top down to shared primitives at the bottom. Each band depends on the
 * bands below it; everything converges on `primitives`. Authored as an Astro
 * component (raw SVG is first-class); the MDX page only references <CrateStack />.
 *
 * Layout is computed in the frontmatter so the crate chips wrap cleanly and
 * stay in sync with the layer tables on the page.
 */

interface Layer {
  lines: string[];
  accent: string;
  fill: string;
  crates: string[];
}

const layers: Layer[] = [
  { lines: ['Binaries', '& tools'], accent: '#e3b341', fill: '#231708',
    crates: ['merod', 'meroctl', 'calimero-abi', 'mero-sign', 'merodb'] },
  { lines: ['Client &', 'Server'], accent: '#a5ff11', fill: '#13160f',
    crates: ['server', 'mero-auth', 'client'] },
  { lines: ['Node &', 'Context'], accent: '#3fb950', fill: '#10210f',
    crates: ['node', 'context', 'context-config', 'config'] },
  { lines: ['Sync · Network', 'Runtime · Store'], accent: '#58a6ff', fill: '#10151c',
    crates: ['network', 'runtime', 'store', 'store-rocksdb', 'store-blobs', 'store-encryption', 'storage'] },
  { lines: ['Governance', 'Op · DAG'], accent: '#39d0d8', fill: '#10201f',
    crates: ['dag', 'op', 'projection', 'authz', 'op-adapter', 'governance-types', 'governance-store'] },
  { lines: ['SDK &', 'Primitives'], accent: '#a371f7', fill: '#1a1430',
    crates: ['sdk', 'sys', 'wasm-abi', 'primitives', 'prelude', 'crypto', 'tee-attestation'] },
];

const W = 760;
const MARGIN = 20;
const TOP = 64;
const LABEL_X = 28;
const CHIP_X = 184;
const CHIP_W = 84;
const CHIP_H = 26;
const CHIP_GX = 8;
const CHIP_GY = 8;
const PER_ROW = 6;
const PAD = 10;
const BAND_GAP = 14;

interface Chip { x: number; y: number; label: string }
interface Band { x: number; y: number; w: number; h: number; accent: string; fill: string; lines: string[]; cx: number; midY: number; chips: Chip[] }

let y = TOP;
const bands: Band[] = layers.map((layer) => {
  const rows = Math.ceil(layer.crates.length / PER_ROW);
  const h = PAD * 2 + rows * CHIP_H + (rows - 1) * CHIP_GY;
  const chips: Chip[] = layer.crates.map((label, i) => ({
    x: CHIP_X + (i % PER_ROW) * (CHIP_W + CHIP_GX),
    y: y + PAD + Math.floor(i / PER_ROW) * (CHIP_H + CHIP_GY),
    label,
  }));
  const band: Band = {
    x: MARGIN, y, w: W - MARGIN * 2, h,
    accent: layer.accent, fill: layer.fill, lines: layer.lines,
    cx: (MARGIN + CHIP_X) / 2, midY: y + h / 2, chips,
  };
  y += h + BAND_GAP;
  return band;
});

const H = y - BAND_GAP + 34; // last band bottom + caption room
---
<div class="cratestack">
<svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label="Calimero crate stack" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <marker id="cs-head" markerWidth="8" markerHeight="8" refX="5.5" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6 Z" fill="#6b7280"/>
    </marker>
  </defs>
  <rect x="0" y="0" width={W} height={H} rx="12" fill="#0d1117"/>

  <text x="20" y="28" fill="#f0f6fc" font-family="ui-sans-serif, system-ui" font-size="13" font-weight="600">The crate stack — external surfaces down to shared primitives</text>
  <text x="20" y="46" fill="#8b949e" font-family="ui-sans-serif, system-ui" font-size="9.5">each layer depends on the layers below it; every crate ultimately converges on `primitives`</text>
  <text x={W - 20} y="46" text-anchor="end" fill="#6b7280" font-family="ui-sans-serif, system-ui" font-size="9.5">depends ↓</text>

  {bands.map((band) => (
    <g>
      <rect x={band.x} y={band.y} width={band.w} height={band.h} rx="10" fill={band.fill} stroke={band.accent} stroke-width="1.4"/>
      {band.lines.map((line, li) => (
        <text x={LABEL_X} y={band.midY - (band.lines.length - 1) * 7 + li * 14 + 4} fill={band.accent} font-family="ui-sans-serif, system-ui" font-size="11" font-weight="700">{line}</text>
      ))}
      {band.chips.map((chip) => (
        <g>
          <rect x={chip.x} y={chip.y} width={CHIP_W} height={CHIP_H} rx="6" fill="#0d1117" stroke={band.accent} stroke-width="1"/>
          <text x={chip.x + CHIP_W / 2} y={chip.y + CHIP_H / 2 + 3.5} text-anchor="middle" fill="#c9d1d9" font-family="ui-monospace, monospace" font-size="9">{chip.label}</text>
        </g>
      ))}
    </g>
  ))}

  {bands.slice(0, -1).map((band) => (
    <line x1={W / 2} y1={band.y + band.h} x2={W / 2} y2={band.y + band.h + BAND_GAP} stroke="#6b7280" stroke-width="1.1" marker-end="url(#cs-head)"/>
  ))}

  <text x={W / 2} y={H - 10} text-anchor="middle" fill="#6b7280" font-family="ui-sans-serif, system-ui" font-size="9.5">Binaries fan out through the server and node crates into the core libraries — all converging on `primitives`.</text>
</svg>
</div>

<style>
  .cratestack { margin: 1.5rem 0; }
  .cratestack svg { width: 100%; height: auto; border-radius: 12px; }
</style>
